# -------------------------------------------------------
# Terraform
# -------------------------------------------------------

# Provider cache and plugin binaries
.terraform/

# Dependency lock file - commit this if the team should pin provider versions;
# ignore it if each developer runs their own init
# .terraform.lock.hcl

# State files (contain sensitive resource data - never commit)
*.tfstate
*.tfstate.backup

# Saved plan files
*.tfplan

# Crash log
crash.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# -------------------------------------------------------
# Ansible
# -------------------------------------------------------

# Legacy retry files (Ansible < 2.12)
*.retry

# Python bytecode generated by Ansible modules or custom filters
__pycache__/
*.pyc
*.pyo

# Ansible vault password file (never commit)
ansible/.vault_password
ansible/vault_password
.vault_password

# -------------------------------------------------------
# Secrets and credentials
# -------------------------------------------------------

# SSH private keys
*.pem
*.key
id_rsa
id_ed25519

# Environment variable files
.env
.env.*
!.env.example

# -------------------------------------------------------
# OS-generated files
# -------------------------------------------------------

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# -------------------------------------------------------
# Editors and IDEs
# -------------------------------------------------------

.vscode/
.idea/
*.swp
*.swo
*~

# -------------------------------------------------------
# Logs
# -------------------------------------------------------

*.log
logs/
